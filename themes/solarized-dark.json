{
  "name": "Solarized Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#002b36",
    "editor.foreground": "#839496",
    "editor.lineNumberColor": "#586e75",
    "editor.lineHighlightBackground": "#073642",
    "editor.selectionBackground": "#073642",
    "editorCursor.foreground": "#93a1a1",
    "editorWhitespace.foreground": "#073642",
    "editorBracketMatch.background": "#073642",
    "editorBracketMatch.border": "#268bd2",
    "statusBar.background": "#073642",
    "statusBar.foreground": "#93a1a1",
    "sideBar.background": "#002b36",
    "sideBar.foreground": "#839496",
    "activityBar.background": "#002b36",
    "activityBar.foreground": "#268bd2",
    "terminal.background": "#002b36",
    "terminal.foreground": "#839496",
    "terminal.ansiRed": "#dc322f",
    "terminal.ansiGreen": "#859900",
    "terminal.ansiYellow": "#b58900",
    "terminal.ansiBlue": "#268bd2",
    "terminal.ansiMagenta": "#2aa198",
    "terminal.ansiCyan": "#6c71c4"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment"],
      "settings": {"foreground": "#586e75"}
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": {"foreground": "#2aa198"}
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {"foreground": "#d33682"}
    },
    {
      "name": "Keyword",
      "scope": ["keyword"],
      "settings": {"foreground": "#859900"}
    },
    {
      "name": "Class name",
      "scope": ["entity.name.class"],
      "settings": {"foreground": "#268bd2"}
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function"],
      "settings": {"foreground": "#268bd2"}
    }
  ]
}
