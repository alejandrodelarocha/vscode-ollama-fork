{
  "name": "Tokyo Night",
  "type": "dark",
  "colors": {
    "editor.background": "#1a1b26",
    "editor.foreground": "#c0caf5",
    "editor.lineNumberColor": "#565f89",
    "editor.lineHighlightBackground": "#292e42",
    "editor.selectionBackground": "#3e4b59",
    "editorCursor.foreground": "#c0caf5",
    "editorWhitespace.foreground": "#3b4261",
    "editorBracketMatch.background": "#3e4b59",
    "editorBracketMatch.border": "#7aa2f7",
    "statusBar.background": "#292e42",
    "statusBar.foreground": "#c0caf5",
    "sideBar.background": "#1a1b26",
    "sideBar.foreground": "#c0caf5",
    "activityBar.background": "#1a1b26",
    "activityBar.foreground": "#7aa2f7",
    "terminal.background": "#1a1b26",
    "terminal.foreground": "#c0caf5",
    "terminal.ansiRed": "#f7768e",
    "terminal.ansiGreen": "#9ece6a",
    "terminal.ansiYellow": "#e0af68",
    "terminal.ansiBlue": "#7aa2f7",
    "terminal.ansiMagenta": "#bb9af7",
    "terminal.ansiCyan": "#7dcfff"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment"],
      "settings": {"foreground": "#565f89"}
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": {"foreground": "#9ece6a"}
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {"foreground": "#ff9e64"}
    },
    {
      "name": "Keyword",
      "scope": ["keyword"],
      "settings": {"foreground": "#bb9af7"}
    },
    {
      "name": "Class name",
      "scope": ["entity.name.class"],
      "settings": {"foreground": "#7aa2f7"}
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function"],
      "settings": {"foreground": "#7aa2f7"}
    },
    {
      "name": "Function argument",
      "scope": ["variable.parameter"],
      "settings": {"foreground": "#e0af68"}
    }
  ]
}
