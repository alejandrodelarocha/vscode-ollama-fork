{
  "name": "Gruvbox Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#282828",
    "editor.foreground": "#ebdbb2",
    "editor.lineNumberColor": "#928374",
    "editor.lineHighlightBackground": "#3c3836",
    "editor.selectionBackground": "#504945",
    "editorCursor.foreground": "#ebdbb2",
    "editorWhitespace.foreground": "#3c3836",
    "editorBracketMatch.background": "#504945",
    "editorBracketMatch.border": "#83a598",
    "statusBar.background": "#3c3836",
    "statusBar.foreground": "#ebdbb2",
    "sideBar.background": "#282828",
    "sideBar.foreground": "#ebdbb2",
    "activityBar.background": "#282828",
    "activityBar.foreground": "#83a598",
    "terminal.background": "#282828",
    "terminal.foreground": "#ebdbb2",
    "terminal.ansiRed": "#cc241d",
    "terminal.ansiGreen": "#98971a",
    "terminal.ansiYellow": "#d79921",
    "terminal.ansiBlue": "#458588",
    "terminal.ansiMagenta": "#b16286",
    "terminal.ansiCyan": "#689d6a"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment"],
      "settings": {"foreground": "#928374"}
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": {"foreground": "#b8bb26"}
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {"foreground": "#d3869b"}
    },
    {
      "name": "Keyword",
      "scope": ["keyword"],
      "settings": {"foreground": "#f84934"}
    },
    {
      "name": "Class name",
      "scope": ["entity.name.class"],
      "settings": {"foreground": "#8ec07c"}
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function"],
      "settings": {"foreground": "#8ec07c"}
    }
  ]
}
